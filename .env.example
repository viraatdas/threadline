# Application authentication (Google OAuth through Auth.js)
AUTH_SECRET=replace-with-a-random-secret
AUTH_GOOGLE_ID=replace-with-google-oauth-client-id
AUTH_GOOGLE_SECRET=replace-with-google-oauth-client-secret
OWNER_EMAIL=owner@example.com

# Generic Postgres connection used by Drizzle
DATABASE_URL=postgres://postgres:postgres@localhost:5432/threadline

# Base64-encoded 32-byte key for AES-256-GCM integration credential encryption
INTEGRATION_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
INTEGRATION_ENCRYPTION_KEY_VERSION=1

# Public origin used by Auth.js and background callbacks
AUTH_URL=http://localhost:3000

# Optional local/subscription-backed analysis runner. No hosted LLM API key is used.
ANALYSIS_RUNNER=codex-cli
CODEX_COMMAND=codex
