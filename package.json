{
  "name": "threadline",
  "version": "0.1.0",
  "private": true,
  "description": "A quiet, owner-only relationship intelligence workspace.",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver"]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:dashboard && pnpm test:people-outreach && pnpm test:gmail && pnpm test:linkedin && pnpm test:x && pnpm test:sync && pnpm test:codex-worker",
    "test:unit": "vitest run",
    "test:dashboard": "vitest run --config tests/dashboard/vitest.config.ts",
    "test:people-outreach": "vitest run --config tests/people-outreach/vitest.config.ts",
    "test:gmail": "vitest run --config tests/gmail/vitest.config.ts",
    "test:linkedin": "vitest run --config tests/linkedin/vitest.config.ts",
    "test:x": "vitest run --config tests/x/vitest.config.ts",
    "test:sync": "vitest run --config tests/sync/vitest.config.ts",
    "test:codex-worker": "vitest run --config tests/codex-worker/vitest.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx lib/db/migrate.ts",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm e2e"
  },
  "dependencies": {
    "@jtsang/bird": "0.8.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "@radix-ui/react-popover": "1.1.19",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.7",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.12",
    "@tanstack/react-table": "8.21.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.4.0",
    "drizzle-orm": "0.45.2",
    "googleapis": "173.0.0",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "3.9.2",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "postcss": "8.5.6",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
